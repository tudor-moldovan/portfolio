{
  "version": 2,
  "routes": [
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/img/(.*)", "dest": "/img/$1" },
    {
      "src": "/(index.html)?",
      "dest": "/index.html",
      "headers": {
        "Cache-Control": "no-cache, no-store, must-revalidate"
      }
    }
  ],
  "crons": [
    {
      "path": "/api/cron",
      "schedule": "30 14 * * 1-5"
    }
  ]
}
